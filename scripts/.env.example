# Example environment for signals infra deploys. Copy to
# scripts/.env.${ENVIRONMENT} (e.g. scripts/.env.prod) and fill in real
# values. scripts/.env.* is gitignored; this file is the one exception.
#
# deploy-infra.sh sources this before running `az deployment group
# create`, so every variable here is a required or optional secret the
# Bicep template consumes.

# DAILY_RAW_KEY — the plaintext key the Logic App sends in the x-api-key
# header when it POSTs to /api/daily. Pair with DAILY_API_KEYS's hashed
# entry. Mint with: pnpm run generate:api-key daily logic-app
DAILY_RAW_KEY=pk_daily_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DAILY_API_KEYS — comma-separated {sourceId}:sha256:{hex} entries the
# /api/daily handler validates incoming keys against. At least one entry
# required. Pair the sourceId with DAILY_RAW_KEY's corresponding hash.
DAILY_API_KEYS=logic-app:sha256:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET — GitHub OAuth App credentials
# for SWA login. Create the OAuth App at
# https://github.com/settings/developers with Authorization callback
# URL https://<swa-hostname>/.auth/login/github/callback. Then invite
# your GitHub identity to the `signals_admin` role via the SWA portal.
GITHUB_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MCP_API_KEYS — optional. Same shape as DAILY_API_KEYS, scoped to
# /api/mcp. Mint with: pnpm run generate:api-key mcp <source-id>.
# Leave empty to disable MCP authentication (the endpoint itself may
# be wired in a later phase).
MCP_API_KEYS=
